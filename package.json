  "homepage": "https://github.com/jinghaihan/mhrise-cheat-generator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinghaihan/mhrise-cheat-generator.git"
  },
  "bugs": {
    "url": "https://github.com/jinghaihan/mhrise-cheat-generator/issues"
