  "dependencies": {
    "vue-i18n": "catalog:",
    "@ant-design/icons-vue": "catalog:frontend",
    "@unhead/vue": "catalog:frontend",
    "ant-design-vue": "catalog:frontend",
    "pinia": "catalog:frontend",
    "vue": "catalog:frontend",
    "vue-router": "catalog:frontend",
    "file-saver": "catalog:prod",
    "jszip": "catalog:prod",
    "lodash-es": "catalog:prod",
    "xlsx": "catalog:prod"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:build",
    "@vitejs/plugin-vue-jsx": "catalog:build",
    "vite": "catalog:build",
    "vite-plugin-svg-icons": "catalog:build",
    "fast-glob": "catalog:dev",
    "less": "catalog:dev",
    "less-loader": "catalog:dev",
    "pncat": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "taze": "catalog:dev",
    "typescript": "catalog:dev",
    "@octohash/eslint-config": "catalog:lint",
    "eslint": "catalog:lint",
    "lint-staged": "catalog:lint",
    "vue-tsc": "catalog:lint",
    "vitest": "catalog:test",
    "@types/file-saver": "catalog:types",
    "@types/lodash-es": "catalog:types"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
